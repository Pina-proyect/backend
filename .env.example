# ──────────────────────────────────────────────
# PINA BACKEND — Variables de Entorno
# Copiar a .env y reemplazar valores
# ──────────────────────────────────────────────

# ── Base de Datos ─────────────────────────────
# PostgreSQL (local con Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pina_dev"
# Conexión directa (para migraciones, bypass del pooler)
DIRECT_URL=

# ── Google OAuth ──────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# En desarrollo: http://localhost:4011/api/pina/auth/google/callback
# En staging:   https://<render-url>/api/pina/auth/google/callback
GOOGLE_CALLBACK_URL="http://localhost:4011/api/pina/auth/google/callback"

# ── JWT ───────────────────────────────────────
JWT_SECRET=""                              # Generar con: openssl rand -hex 32
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Seguridad ─────────────────────────────────
BCRYPT_SALT_ROUNDS="10"

# ── URLs ──────────────────────────────────────
# Frontend (Next.js por defecto corre en :3000)
FRONTEND_URL="http://localhost:3000"
# Backend (para callbacks internos)
BACKEND_URL="http://localhost:4011"
# Orígenes CORS adicionales (separados por coma)
CORS_ORIGINS=""
# Tunnel ngrok para webhooks en desarrollo
NGROK_URL=""

# ── Mercado Pago ──────────────────────────────
# Token productivo (solo en Render, no en .env local)
MP_ACCESS_TOKEN=""
# OAuth para que creadoras conecten su cuenta MP
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
# Callback OAuth: https://<backend>/api/pina/payments/mercadopago/callback
MP_REDIRECT_URI=""
# Secreto para validar webhooks HMAC-SHA256
MP_WEBHOOK_SECRET=""

# ── Redis ─────────────────────────────────────
# Redis://... (local: redis://localhost:6379)
REDIS_URL=""

# ── Servidor ──────────────────────────────────
PORT=4011
NODE_ENV="development"                     # development | production | test

# ── Resend (Email) ─────────────────────────────
RESEND_API_KEY="re_..."                          # https://resend.com/api-keys
EMAIL_FROM="Pina <noreply@pina.com>"             # Debe ser dominio verificado en Resend

# ── Prisma (opcional) ─────────────────────────
# Prisma connection pool settings
PRISMA_CLIENT_CONNECTION_LIMIT=10
PRISMA_CLIENT_POOL_TIMEOUT=10
